float sq(float t) {
    return t * t;
}

float seg(vec2 s, vec2 e, vec2 p) {
    float len = length(e - s);
    vec2 v = (e - s) / len;
    float t = dot(v, p - s) / len;
    if (t > 1.) return length(p - e);
    else if (t < 0.) return length(p - s);
    else return sqrt(sq(length(p-s)) - sq(dot(p-s, v)));
}

vec2 rot(vec2 p, float a) {
    float rad = a * 3.141592 / 180.;
    float c = cos(rad);
    float s = sin(rad);
    return vec2(p.x * c - p.y * s,
                p.x * s + p.y * c);
}

