float curve(in vec2 p, int start, int end)
{
        float ret = 0.;

        for (int i = start; i < end; ++i) {
            vec2 A = points[i];
            vec2 B = points[i + 1];
            
            vec2 d = B - A;
            float k = d.y / d.x;
            float m = A.y - k * A.x;

            ret += abs(step(B.x, p.x) - step(A.x, p.x)) * step(p.y, k * p.x + m);
        }

        return ret;
}

float glyph(in vec2 p, int start, int end)
{
    float d = 0.;

    for (int i = start; i < end; ++i) {
        d += curve(p, curves[i], curves[i + 1] - 1);
    }

    return mod(d, 2.);
}

// https://stackoverflow.com/a/26697650/1697183
float insideBox( in vec2 p, in vec4 box )
{
    vec2 s = step(box.zw, p) - step(box.xy, p);
    return s.x * s.y;
}

// http://www.iquilezles.org/www/articles/distfunctions2d/distfunctions2d.htm
float sdLine( in vec2 p, in vec2 a, in vec2 b )
{
    vec2 pa = p-a, ba = b-a;
    float h = clamp( dot(pa,ba)/dot(ba,ba), 0.0, 1.0 );
    return length( pa - ba*h );
}

float sdCurve(in vec2 p, int start, int end)
{
    float d = 1e16;

    for (int i = start; i < end; ++i) {
        vec2 A = points[i];
        vec2 B = points[i + 1];
        d = min(d, sdLine(p, A, B));
    }

    return d;
}

float sdGlyph(in vec2 p, int start, int end)
{
    float d = 1e16;

    for (int i = start; i < end; ++i) {
        d = min(d, sdCurve(p, curves[i], curves[i + 1] - 1));
    }

    return d;
}

uniform int zero;

float text(vec2 p)
{
    float d = 1e16;

    for (int i = zero; i < 73; ++i) {
        if (insideBox(p, letters[i].box + 100.*vec4(-1, -1, 1, 1)) > 0.) {
            int glyph_index = letters[i].glyph_index;
            if (glyph(p - letters[i].pos, glyphs[glyph_index], glyphs[glyph_index + 1]) > 0.) {
                // fill
                d = 0.;
            } else {
                // outline
                d = min(d, sdGlyph(p - letters[i].pos, glyphs[glyph_index], glyphs[glyph_index + 1]));
            }
        }
    }

    return d;
}

void main(void)
{
    vec2 uv = (gl_FragCoord.xy - vec2(.5 * resolution.x, 0)) / resolution.y - vec2(0, .5);
    uv *= 10000.;
    uv.x -= 500. * 50.;
    uv.x += 500.*mod(time, 120.);
    float col = text(uv);
    glFragColor = vec4(vec3(smoothstep(-1., 20., col)), 1.0);
}
