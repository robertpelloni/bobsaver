//--- auxiliary functions ---//

float hash(float seed) { return fract(sin(seed)*43758.5453); }

float sdBox(vec3 p, vec3 b) { vec3 q = abs(p) - b; return length(max(q,0.0)) + min(max(q.x,max(q.y,q.z)),0.0); }

//--- geometry ---//

float dist(vec3 p)
{
    vec3 z = p;
    
    if (abs(z.x) < 6.0) z.x = sin(z.x) + 0.1 * sin(2.4 * z.x);
    
    for (int n = 0; n < 8; n++)
    {
        if (z.x + z.y < 0.0) z.xy = -z.yx;
        if (z.x + z.z < 0.0) z.xz = -z.zx;
        if (z.y + z.z < 0.0) z.zy = -z.yz;
        
        z = 2.0 * z - vec3(1.0);
    }
    
    float d = (length(z) - 2.0) / 512.0;
    d = max(d, sdBox(p, vec3(4.8)));
    return min(d, sdBox(p + vec3(0.0, 1.2, 0.0), vec3(6.0, 0.2, 4.0)));
}

//--- normal ---//

vec3 calcNormal(in vec3 pos)
{
    vec3 eps = vec3(0.0001,0.0,0.0);
    
    return normalize(vec3(
      dist(pos+eps.xyy) - dist(pos-eps.xyy),
      dist(pos+eps.yxy) - dist(pos-eps.yxy),
      dist(pos+eps.yyx) - dist(pos-eps.yyx)));
}

//--- function taken from https://www.shadertoy.com/view/MdfGRr by iq ---//

vec2 isphere( in vec4 sph, in vec3 ro, in vec3 rd )
{
    vec3 oc = ro - sph.xyz;
    
    float b = dot(oc,rd);
    float c = dot(oc,oc) - sph.w*sph.w;
    float h = b*b - c;
    if( h<0.0 ) return vec2(-1.0);
    h = sqrt( h );
    return -b + vec2(-h,h);
}

//--- sphere tracing with sphere bounding volume ---//

float intersect(in vec3 ro, in vec3 rd)
{
    vec2 dis = isphere(vec4(0.0, 0.0, 0.0, 7.1), ro, rd);
    if(dis.y < 0.0) return -1.0;

    float t = max(0.0, dis.x);
    float res = -1.0;
    float tmax = 25.0;
    
    for (int i = 0; i < 80; i++)
    {
        float h = dist(ro + rd*t);
        if (h < 0.0001 || t > tmax) break;
        t += h;
    }
    
    if (t < tmax) res = t;

    return res;
}

//--- calculates pixel color ---//

vec3 calculateColor(in vec3 ro, in vec3 rd, int s)
{
    vec3 hit = vec3(0.0);
    vec3 hitNormal = vec3(0.0);
    vec3 luminance = vec3(1.0);
    
    for (int bounce = 0; bounce < 2; bounce++)
    {
          float t = intersect(ro, rd);

        if (t > 0.0)
        {
            hit = ro + t*rd;
            hitNormal = calcNormal(hit);
            rd = dirs[2*s + bounce];
            if (dot(rd, hitNormal) < 0.0) rd = -rd;
            
            vec3 color = vec3(0.4, 0.6, hit.y < 0.2 ? 0.40 : 0.82);
            
            luminance *= color * dot(rd, hitNormal);
            ro = hit + 0.002 * hitNormal;
        }
        else 
        {
            if (bounce == 0) return vec3(0.0);
              return 2.4 * luminance * vec3(0.6, 0.7, 0.8);
        }
    }
    
      return vec3(0.0);
}

//--- camera functions ---//

mat3 setCamera(in vec3 ro, in vec3 rt, in float cr)
{
    vec3 cw = normalize(rt-ro);
    vec3 cp = vec3(sin(cr), cos(cr), 0.0);
    vec3 cu = normalize( cross(cw,cp));
    vec3 cv = normalize( cross(cu,cw));
    return mat3(cu, cv, -cw);
}

//--- final color ---//

void main(void)
{
    vec3 final_color = vec3(0.0);
    
    for (int s = 0; s < SAMPLE_COUNT; s++)
    {
        float sa = hash( dot( gl_FragCoord.xy, vec2(12.9898, 78.233) ) + 3213.1*float(s) );
        vec2 of = -0.5 + vec2( hash(sa+13.271), hash(sa+63.216) );
        
        vec2 p = (-resolution.xy + 2.0*(gl_FragCoord.xy+of)) / resolution.y;

        vec3 ro = vec3(9.0*cos(0.4*time + 1.0),3.5,5.0*sin(0.4*time + 1.0));
        vec3 ta = vec3(0.0,0.0,0.0);

        mat3  ca = setCamera(ro, ta, 0.0);
        vec3  rd = normalize(ca * vec3(p,-1.3));

        final_color += calculateColor(ro, rd, s);
    }

    final_color *= 1.0 / float(SAMPLE_COUNT);
    final_color = pow(final_color, vec3(1.0/1.784)); 
    
    glFragColor = vec4(final_color, 1.0);
}
