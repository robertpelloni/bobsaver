struct hit_test {
    vec4 p;
    float t;
};

hit_test h_t(vec3 ro, vec3 rd, vec4 p) {
    hit_test Out;
    float dp = dot(rd, p.xyz);
    float t = (-p.w - dot(p.xyz, ro))/dp;
    Out.t = t;
    Out.p = p;
    return Out;
}

void main(void)
{    
    init_planes();
    
    vec3 rd;
    rd.xy = 2.0*gl_FragCoord.xy/resolution.xy - 1.0;
    rd.x *= resolution.x/resolution.y;
    rd.z = 1.0;
    vec3 ro = vec3(0.0,0.0,-2.0);
    
    glFragColor = vec4(-normalize(rd).y);
    
    float fi = time*0.5;
    vec2 a = vec2(cos(fi), sin(fi));
    mat2 rot = mat2(a, -a.y, a.x);    
    ro.xz = rot*ro.xz;
    rd.xz = rot*rd.xz;

    hit_test res = h_t(ro, rd, planes[0]);
    hit_test h;
    bool inited = false;
    for (int i=0; i < planes_cnt; i++) {
        if (dot(rd, planes[i].xyz) < 0.0) {
            h = h_t(ro, rd, planes[i]);
            if (h.t > 0.0) {
                if (!inited||(h.t > res.t)) {
                    res = h;
                    inited = true;
                }
            }
        }
    }
    
    for (int i=0; i < planes_cnt; i++) {
        if (dot(rd, planes[i].xyz) > 0.0) {
            h = h_t(ro, rd, planes[i]);
            if (h.t < res.t) return;
        }
    }
    
    if (!inited) return;
    
    glFragColor=vec4(vec3(-dot(res.p.xyz, rd)),1.0);
}
