mat3 rot3xy( vec2 angle )
{
    vec2 c = cos( angle );
    vec2 s = sin( angle );
    
    return mat3(
        c.y,        -s.y,        0.0,    
        s.y * c.x,    c.y * c.x,    -s.x,
        s.y * s.x,    c.y * s.x,    c.x        
    );
}

vec4 DE1( in vec4 v )
{
    float fR = dot( v.xyz, v.xyz );
    vec4 q;
    int k = 0;
    vec3 vO = vec3( 0.0, 0.0, 0.0 );

    for ( int i = 0; i < 32; i++ )
    {
        q = v*g_matIterator1;
        v.xyz = q.xyz;

        if ( dot( v, g_planeReflect1 ) < 0.0 )
        {
            q = v*g_matReflect1;
            v.xyz = q.xyz;
            vO.x += 1.0;
        }
        
        if ( dot( v, g_planeReflect2 ) < 0.0 )
        {
            q = v*g_matReflect2;
            v.xyz = q.xyz;
            vO.y += 1.0;
        }
        
        if ( dot( v, g_planeReflect3 ) < 0.0 )
        {
            q = v*g_matReflect3;
            v.xyz = q.xyz;
            vO.z += 1.0;
        }

        q = v*g_matIterator2;
        v.xyz = q.xyz;

        v.xyz = v.xyz*g_fScale;
        fR = dot( v.xyz, v.xyz );
        k = i;
    }

    return vec4( vO, ( sqrt( fR ) - 2.0 ) * pow( g_fScale, -float(k+1) ) );
}

void main(void)
{
    vec3 vRayOrig = vec3( -3.0 - sin( time * 0.1 ), 0.0, 0.0 );
    vec2 vUV = (gl_FragCoord.xy- resolution.xy*0.5) / resolution.x;
    float fL = length( vUV );
    vUV /= fL;
    vUV *= 1.0-pow( 1.0-fL, 0.7 );
    vec3 vRayDir = vec3( 1.0, vUV );
    
    mat3 rot = rot3xy( vec2( 0.0, time * 0.1 ) );
    vRayDir = rot * vRayDir;
    vRayOrig = rot * vRayOrig;
    
    vRayDir = normalize( vRayDir );
    
       const float fRadius = 2.0;    
    float b = dot( vRayDir, vRayOrig ) * 2.0;
    float c = dot( vRayOrig, vRayOrig ) - fRadius*fRadius;    
    float ac4 = 4.0 * c;
    float b2 = b*b;
        
    glFragColor.a = 1.0;
    glFragColor.rgb = -vRayDir*0.2+0.8;
    glFragColor.rgb = pow( glFragColor.rgb, vec3( 0.9, 0.8, 0.5 ) );
    glFragColor.rgb *= 1.0-fL;
    if ( b2 - ac4 <= 0.0 )
    {        
        return;
    }
    
    float root = sqrt( b2-ac4 );
    float at1 = ( -b - root ) / 2.0;
    float at2 = ( -b + root ) / 2.0;

    at1 = max( 0.0, at1 );
    
    
    float t = at1;
    vec4 v = vec4( vRayOrig + vRayDir * t, 1.0 );
    vec4 vDE = vec4( 0.0, 0.0, 0.0, 0.0 );
    float fEpsilon = 0.0;

    float fEpsilonHelper = 1.0/resolution.x;
    
    for ( int k = 0; k < 100; k++ )
    {
        vDE = DE1( v );
        t += vDE.w;
        v.xyz = vRayOrig + vRayDir * t;

        fEpsilon = fEpsilonHelper * t;
        
        if ( vDE.a < fEpsilon )
        {
            break;
        }
        if ( t > at2 )
        {
            return;
        }
    }

    vec4 vOffset = vec4( fEpsilon*1.5, 0.0, 0.0, 0.0 );
    vec4 vNormal;
    vNormal.x = DE1( v + vOffset.xyzw ).w - DE1( v - vOffset.xyzw ).w;
    vNormal.y = DE1( v + vOffset.yxzw ).w - DE1( v - vOffset.yxzw ).w;
    vNormal.z = DE1( v + vOffset.zyxw ).w - DE1( v - vOffset.zyxw ).w;
    vNormal.w = 0.0;
    vNormal.xyz = normalize( vNormal.xyz );
    
    vec4 vReflect = vec4( 0.0, 0.0, 0.0, 0.0 );
    vReflect.xyz = reflect( vRayDir, vNormal.xyz );

    vec2 vOccRefl = vec2( 0.0, 0.0 );
    {    
        float fMul = 2.0;
        float fMulMul = pow( 2.0, 9.0/10.0 ) * pow( fEpsilon, 1.0/10.0 ) * 0.5;
        float fW = 0.0;
        for ( int k = 0; k < 10; k++ )
        {
            vOccRefl.x += DE1( v + vNormal * fMul ).w / fMul;
            vOccRefl.y += DE1( v + vReflect * fMul ).w / fMul;
            fMul *= fMulMul;
        }
        vOccRefl /= 10.0;
    }
    glFragColor.xyz = vec3( vOccRefl.x * vOccRefl.y );
    glFragColor.xyz *= (vNormal.xyz*0.5+0.5)*(1.0-glFragColor.x) + vec3( 1.0, 1.0, 1.0 ) * glFragColor.x;
    glFragColor.rgb = pow( glFragColor.rgb, vec3( 0.9, 0.8, 0.7 ) );
    //glFragColor.rgb = 1.0-exp( -glFragColor.rgb*2.0 );
    glFragColor.rgb *= (1.0-fL)*1.2;    
}
