#version 420

// original https://www.shadertoy.com/view/WtdXRS

uniform float time;
uniform vec2 mouse;
uniform vec2 resolution;

out vec4 glFragColor;

// Based on https://www.shadertoy.com/view/ldGBRd
// excel parsed .obj vertices makes this a simple copy past to any model I guess

float distLine(vec3 ro, vec3 rd, vec3 p) {
    return length(cross(p-ro, rd)) / length(rd);
}

float drawPoint(vec3 ro, vec3 rd, vec3 p) {
    p -= .5; // move cube to center of screen
    float d = distLine(ro, rd, p);
    d = smoothstep(.01, .001, d);
    return d;
}

