// Estimate y for given x, that `y = asinh(sin(x - y))`,
// using binary search and linear interpolation.
float f(in float x) {
    x = mod(x, TWOPI);
    
    bool greaterThanPI = false;
    if (x == PI) return 0.0;
    if (x > PI) {
        x = TWOPI - x;
        greaterThanPI = true;
    }
    
    int start = 0;
    int end = pts.length();
    
    while (end - start > 1) {
        int middle = (start + end) / 2;
        if (x < pts[middle].x) end = middle;
        else start = middle;
    }
    
    vec2 a = pts[start];
    vec2 b = pts[start + 1];
    float y = mix(a.y, b.y, (x - a.x) / (b.x - a.x));
    
    if (isnan(y)) y = 0.0;
    return greaterThanPI ? -y : y;
}

void main(void) {
    vec2 xy = 8.0 * (gl_FragCoord.xy - 0.5 * resolution.xy) / resolution.y;
    
    #ifdef USE_POLAR
    float r = log(length(xy));
    float a = atan(xy.y, xy.x);
    #else
    float r = xy.y;
    float a = xy.x;
    #endif
    
    vec2 mouse = mouse*resolution.xy.xy / resolution.xy - 0.5;
    // controls the shape of the spiral
    float k = mouse.x * 8.0;
    // controls the width of color bands
    float w = mouse.y * 4.0;
    
    float d = (f(a - r * k) / k + r) - (time / 2.0);
    d /= w;
    
    #ifdef USE_STEP
    d = floor(d * 8.0) / 8.0;
    #endif
    
    glFragColor = vec4(sinebow(d), 1.0);
}
