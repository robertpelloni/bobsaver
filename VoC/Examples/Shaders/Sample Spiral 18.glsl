#define PI 3.141592653589793
#define TWOPI 6.283185307179586

// An less angry hcl color ring.
vec3 sinebow(in float d) {
    return vec3(
        sin(TWOPI * d),
        sin(TWOPI * (d + 1.0 / 3.0)),
        sin(TWOPI * (d + 2.0 / 3.0))
    ) * 0.5 + 0.5;
}

