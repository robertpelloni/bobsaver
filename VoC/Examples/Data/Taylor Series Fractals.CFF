[Shader]
Total Lines=252
Line 0="#version 400"
Line 1=""
Line 2="//the following uniform values are set by Visions of Chaos prior to shader execution"
Line 3="uniform vec2 resolution;"
Line 4="uniform vec3 palette[256];"
Line 5="uniform double xmin;"
Line 6="uniform double xmax;"
Line 7="uniform double ymin;"
Line 8="uniform double ymax;"
Line 9="uniform double bailout;"
Line 10="uniform int maxiters;"
Line 11="uniform int samplepixels;"
Line 12=""
Line 13="#define FLT_MAX 3.402823466e+38"
Line 14="#define FLT_MIN 1.175494351e-38"
Line 15="#define DBL_MAX 1.7976931348623158e+308"
Line 16="#define DBL_MIN 2.2250738585072014e-308"
Line 17=""
Line 18="double sqrsamplepixels=double(samplepixels*samplepixels);"
Line 19="double bailout_squared=double(bailout*bailout);"
Line 20="double magnitude,r1,r2,g1,g2,b1,b2,tweenval;"
Line 21="float realiters;"
Line 22="vec4 finalcol,col;"
Line 23="int superx,supery;"
Line 24="double stepx=(xmax-xmin)/resolution.x/double(samplepixels);"
Line 25="double stepy=(ymax-ymin)/resolution.y/double(samplepixels);"
Line 26="int index,colval,colval2;"
Line 27="dvec2 z,c;"
Line 28=""
Line 29="//------------------------------------------------------------"
Line 30="// complex number operations"
Line 31="dvec2 cadd( dvec2 a, dvec2 b ) { return dvec2( a.x+b.x, a.y+b.y ); }"
Line 32="dvec2 csub( dvec2 a, dvec2 b ) { return dvec2( a.x-b.x, a.y-b.y ); }"
Line 33="dvec2 cmul( dvec2 a, dvec2 b )  { return dvec2( a.x*b.x - a.y*b.y, a.x*b.y + a.y*b.x ); }"
Line 34="dvec2 cdiv( dvec2 a, dvec2 b )  { double d = dot(b,b); return dvec2( dot(a,b), a.y*b.x - a.x*b.y ) / d; }"
Line 35="dvec2 csqr( dvec2 a ) { return dvec2(a.x*a.x-a.y*a.y, 2.0*a.x*a.y ); }"
Line 36="dvec2 csqrt( dvec2 z ) { double m = length(z); return sqrt( 0.5*dvec2(m+z.x, m-z.x) ) * dvec2( 1.0, sign(z.y) ); }"
Line 37="dvec2 conj( dvec2 z ) { return dvec2(z.x,-z.y); }"
Line 38="dvec2 c_from_polar(double r, double theta) { return dvec2(r * cos(float(theta)), r * sin(float(theta))); }"
Line 39="dvec2 c_to_polar(dvec2 c) { return dvec2(length(c), atan(float(c.y),float(c.x))); }"
Line 40="/// Raises `c` to a floating point power `e`."
Line 41="dvec2 c_pow(dvec2 c, double e) {"
Line 42="  dvec2 p = c_to_polar(c);"
Line 43="  return c_from_polar(pow(float(p.x),float(e)), p.y*e);"
Line 44="}"
Line 45=""
Line 46="/// Raises `c` to a complex power `e`."
Line 47="dvec2 c_pow(dvec2 c, dvec2 e) {"
Line 48="  dvec2 polar = c_to_polar(c);"
Line 49="  return c_from_polar("
Line 50="     pow(float(polar.x),float(e.x)) * exp(float(-e.y * polar.y)),"
Line 51="     e.x * polar.y + e.y * log(float(polar.x))"
Line 52="  );"
Line 53="}"
Line 54="/// Returns the logarithm of `c` with respect to an arbitrary base."
Line 55="dvec2 c_log(dvec2 c, double base) {"
Line 56="  dvec2 polar = c_to_polar(c);"
Line 57="  return dvec2(log(float(polar.r)), polar.y) / log(float(base));"
Line 58="}"
Line 59="/// Computes the principal value of natural logarithm of `c`."
Line 60="dvec2 c_ln(dvec2 c) {"
Line 61="  dvec2 polar = c_to_polar(c);"
Line 62="  return dvec2(log(float(polar.x)), polar.y);"
Line 63="}"
Line 64="dvec2 c_sinh(dvec2 c) {"
Line 65="  return dvec2(sinh(float(c.x)) * cos(float(c.y)), cosh(float(c.x)) * sin(float(c.y)));"
Line 66="}"
Line 67="// inverse of z"
Line 68="// 1/z = (a - bi)/(a^2 + b^2)"
Line 69="dvec2 invr(dvec2 z) {"
Line 70="	if (z == 0.0) { return dvec2 (1e10); }"
Line 71="	return dvec2 (z.x, -z.y)/(z.x*z.x + z.y*z.y);"
Line 72="}"
Line 73="//// trigonometric functions"
Line 74=""
Line 75="// complex sine"
Line 76="// sin z = sin(a)cosh(b) + cos(a)sinh(b)i"
Line 77="dvec2 csin(dvec2 z) { return dvec2 (0.5*sin(float(z.x))*(exp(float(z.y)) + exp(float(-z.y))), 0.5*cos(float(z.x))*(exp(float(z.y)) - exp(float(-z.y))));"
Line 78="}"
Line 79=""
Line 80="// complex cosine"
Line 81="// cos z = cos(a)cosh(b) - sin(a)sinh(b)i"
Line 82="dvec2 ccos(dvec2 z) { return dvec2 (0.5*cos(float(z.x))*(exp(float(z.y)) + exp(float(-z.y))), -0.5*sin(float(z.x))*(exp(float(z.y)) - exp(float(-z.y))));"
Line 83="}"
Line 84=""
Line 85="// complex tangent"
Line 86="// tan z = sin(z)/cos(z)"
Line 87="dvec2 ctan(dvec2 z) { return cdiv(csin(z), ccos(z));"
Line 88="}"
Line 89=""
Line 90="// complex cotangent"
Line 91="// cot z = cos(z)/sin(z)"
Line 92="dvec2 ccot(dvec2 z) { return cdiv(ccos(z), csin(z));"
Line 93="}"
Line 94=""
Line 95="// complex secant"
Line 96="// sec z = 1/cos(z)"
Line 97="dvec2 csec(dvec2 z) { return invr(ccos(z));"
Line 98="}"
Line 99=""
Line 100="// complex cosecant"
Line 101="// csc z = 1/sin(z)"
Line 102="dvec2 ccsc(dvec2 z) { return invr(csin(z));"
Line 103="}"
Line 104="//------------------------------------------------------------"
Line 105=""
Line 106="void main(void)"
Line 107="{"
Line 108="	bool fMandelbrot = false; //can be true or false"
Line 109="	bool fScalePoint = false; //can be true or false"
Line 110="	bool fCompoundPoint = true; //can be true or false"
Line 111="	bool fRecurse = true; //can be true or false"
Line 112="	int fAlg = 0; //can be 0, 1, or 2"
Line 113="	double fExpPtX = 0.0; // ??"
Line 114="	double fExpPtY = 0.0; // ??"
Line 115="	double fGlow = 5.0; // ??"
Line 116="	double fBrightnessFactor = 10.0; // ??"
Line 117="	int ms = 4;"
Line 118="	double fComplexScale = 1.0; // ??"
Line 119=""
Line 120="  	double lim = 5000;"
Line 121="  	double lim2 = FLT_MAX;"
Line 122="	double MATH_E = exp(1.0);"
Line 123="	dvec2 CONE = dvec2(1.0,0.0);"
Line 124="	dvec2 CTWO = dvec2(2.0,0.0);"
Line 125="	dvec2 CZERO = dvec2(0.0,0.0);"
Line 126="	double den,den2,x,xavg,xmaximum,xtot,tmpmag,xdev;"
Line 127="	dvec2 numerator,denominator,denominator2,twoN1;"
Line 128="	dvec2 p,value,zSum,current,oldcurrent,scale,tmpval;"
Line 129=""
Line 130="	finalcol=vec4(0,0,0,0);"
Line 131="	for (supery=0;supery<samplepixels;supery++)"
Line 132="	{"
Line 133="		for (superx=0;superx<samplepixels;superx++)"
Line 134="		{"
Line 135="			c.x = xmin+gl_FragCoord.x/resolution.x*(xmax-xmin)+(stepx*double(superx));"
Line 136="			c.y = ymin+gl_FragCoord.y/resolution.y*(ymax-ymin)+(stepy*double(supery));"
Line 137="			"
Line 138="			current = dvec2(c.y*ms,-c.x*ms);"
Line 139=""
Line 140="			z = dvec2(0.0,0.0);"
Line 141="  			if (fMandelbrot==true) {"
Line 142="				if (fAlg==0) { z=c_pow(current,MATH_E); }"
Line 143="				if (fAlg==1) { z=c_ln(cdiv(cadd(CONE,current),csub(CONE,current))); }"
Line 144="				if (fAlg==2) { z=c_sinh(current); }"
Line 145="			}"
Line 146=""
Line 147=""
Line 148="  			den=1;"
Line 149="			den2=1;"
Line 150="			xavg=0;"
Line 151="			xmaximum=0;"
Line 152="			xtot=0;"
Line 153=" 			denominator = dvec2(den,0.0);"
Line 154="  			denominator2 = dvec2(den,0.0);"
Line 155=" "
Line 156="  			//expand at f(x - point)"
Line 157="  			p = c_pow(current,MATH_E);"
Line 158="  			p = cadd(p,dvec2(fExpPtX,fExpPtY));"
Line 159="    		value = CZERO;"
Line 160="    		zSum = CZERO;"
Line 161=" "
Line 162="			int i;"
Line 163="			for(i=0; i<maxiters; i++) "
Line 164="			{"
Line 165="    			scale = dvec2(1.0,fComplexScale);"
Line 166="    			oldcurrent = current;"
Line 167="    			if (fScalePoint==true) {"
Line 168="					if (fAlg==0) { scale = c_pow(p,MATH_E); }"
Line 169="					if (fAlg==1) { scale = c_ln(cdiv(cadd(CONE,p),csub(CONE,p))); }"
Line 170="					if (fAlg==2) { scale = c_sinh(p); }"
Line 171="				}"
Line 172=" "
Line 173="    			if (fCompoundPoint==true) { current = csub(current,p); }"
Line 174=" "
Line 175="				//factorial denomidennators"
Line 176="    			if (i>0) {"
Line 177="      				den = den*i;"
Line 178="      				den2 = den2*(i*2+1);"
Line 179="      				denominator = dvec2(den,0.0);"
Line 180="      				denominator2 = dvec2(den2,0.0);"
Line 181="				}"
Line 182=""
Line 183="				if (fAlg==0) {"
Line 184="        			// f(x) = x^n / n!"
Line 185="                	numerator = cmul(scale,c_pow(current,i));"
Line 186="                	zSum = cadd(zSum,cdiv(numerator,denominator));"
Line 187="				}"
Line 188=""
Line 189="				if (fAlg==1) {"
Line 190="        			// f(x) = 2x^(2n-1) / (2n-1)"
Line 191="                	twoN1 = dvec2(2*i-1,0.0);"
Line 192="                	numerator = cmul(scale,cmul(CTWO,c_pow(current,twoN1)));"
Line 193="        			zSum = cadd(zSum,cdiv(numerator,twoN1));"
Line 194="				}"
Line 195=""
Line 196="				if (fAlg==2) {"
Line 197="        			// f(x) = x^(2n+1) / (2n+1)!"
Line 198="        			if (den2>1000) break;"
Line 199="        			numerator = c_pow(current,den2);"
Line 200="                	numerator = cmul(scale,numerator);"
Line 201="        			zSum = cadd(zSum,cdiv(numerator,denominator2));"
Line 202="				}"
Line 203=""
Line 204="    			if (fMandelbrot==true) { zSum = cmul(zSum,csub(z,zSum)); }"
Line 205=" "
Line 206="    			if (fRecurse==false) { current=oldcurrent; }"
Line 207=" "
Line 208="    			if (zSum==dvec2(0.0,0.0)) break;"
Line 209=" "
Line 210="				if (zSum.x < -lim) { zSum.x = -lim; }"
Line 211="				if (zSum.x > lim) { zSum.x = lim; }"
Line 212="				if (zSum.y < -lim) { zSum.x = -lim; }"
Line 213="				if (zSum.y > lim) { zSum.x = lim; }"
Line 214="    			value = ccot(zSum);"
Line 215=" "
Line 216="    			if (isnan(value.x) || isnan(value.y)) break;"
Line 217=" "
Line 218="    			//x = Modulus(ZPower(value,0.1));"
Line 219="				tmpval = c_pow(value,0.1);"
Line 220="				tmpmag = sqrt(tmpval.x*tmpval.x + tmpval.y*tmpval.y);"
Line 221="				x = tmpmag;"
Line 222="    			if (xavg==0) { xavg = x; }"
Line 223=" "
Line 224="    			xdev = abs(x-xavg);"
Line 225="        		xavg = (x*0.5+xavg*(0.5+(0.0001*fGlow)));"
Line 226="        		xmaximum = max(xmaximum,xdev);"
Line 227="        		xtot = xtot + xdev;"
Line 228=""
Line 229=""
Line 230="				"
Line 231="				//magnitude=(z.x * z.x + z.y * z.y);"
Line 232="				//if(magnitude>bailout_squared) break;"
Line 233="			}"
Line 234=""
Line 235="			if (i==maxiters) {"
Line 236="				col=vec4(0.0,0.0,0.0,1.0);"
Line 237="			} else {"
Line 238="				colval = int(((xtot*100)/fBrightnessFactor)/xmaximum);"
Line 239="				r1=palette[colval].r;"
Line 240="				g1=palette[colval].g;"
Line 241="				b1=palette[colval].b;"
Line 242="				col=vec4(r1,g1,b1,1.0);"
Line 243="			}"
Line 244=""
Line 245="			finalcol+=col;"
Line 246="		}"
Line 247="	}"
Line 248="	gl_FragColor = vec4(finalcol/double(sqrsamplepixels));"
Line 249="}"
Line 250="	"
Line 251="	"
