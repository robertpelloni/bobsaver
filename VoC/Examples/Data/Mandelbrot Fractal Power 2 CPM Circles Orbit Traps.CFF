[Settings]
Palette=sinpal14.MAP
Xmin=-2.54203930534979
Xmax=1.78641523127572
Ymin=-1.274431719875
Ymax=1.23336662728241
Bailout=8
Maxiters=512
[Description]
Total Lines=4
Line 0="Mandelbrot Fractal power 2"
Line 1="CPM coloring"
Line 2="Double precision"
Line 3="Circles Orbit Traps"
[Author Info]
Total Lines=2
Line 0="Jason Rampe"
Line 1="http://softology.pro/"
[Shader]
Total Lines=98
Line 0="#version 400"
Line 1=""
Line 2="//the following uniform values are set by Visions of Chaos prior to shader execution"
Line 3="uniform vec2 resolution;"
Line 4="uniform vec3 palette[256];"
Line 5="uniform double xmin;"
Line 6="uniform double xmax;"
Line 7="uniform double ymin;"
Line 8="uniform double ymax;"
Line 9="uniform double bailout;"
Line 10="uniform int maxiters;"
Line 11="uniform int samplepixels;"
Line 12=""
Line 13="double sqrsamplepixels=double(samplepixels*samplepixels);"
Line 14="double bailout_squared=double(bailout*bailout);"
Line 15="double magnitude=0.0,r1,r2,g1,g2,b1,b2,tweenval;"
Line 16="float realiters;"
Line 17="vec4 finalcol,col;"
Line 18="int superx,supery;"
Line 19="double stepx=(xmax-xmin)/resolution.x/double(samplepixels);"
Line 20="double stepy=(ymax-ymin)/resolution.y/double(samplepixels);"
Line 21="int index,colval,colval2;"
Line 22="dvec2 z,c;"
Line 23=""
Line 24="double trapx,trapy,trapsize,trapdist,distpercentage;"
Line 25="bool trapped;"
Line 26=""
Line 27="void main(void)"
Line 28="{"
Line 29="	//center of trap"
Line 30="   trapx=0;"
Line 31="   trapy=0.5;"
Line 32="	//circles trap sizes"
Line 33="	trapsize=0.5;"
Line 34=""
Line 35="	finalcol=vec4(0,0,0,0);"
Line 36="	for (supery=0;supery<samplepixels;supery++)"
Line 37="	{"
Line 38="		for (superx=0;superx<samplepixels;superx++)"
Line 39="		{"
Line 40="			c.x = xmin+gl_FragCoord.x/resolution.x*(xmax-xmin)+(stepx*double(superx));"
Line 41="			c.y = ymin+gl_FragCoord.y/resolution.y*(ymax-ymin)+(stepy*double(supery));"
Line 42="			int i;"
Line 43="			z = dvec2(0.0,0.0);"
Line 44=""
Line 45="         trapped=false;"
Line 46=""
Line 47="			for(i=0; i<maxiters; i++) "
Line 48="			{"
Line 49="				//START OF FRACTAL FORMULA"
Line 50="				double x = (z.x * z.x - z.y * z.y) + c.x;"
Line 51="				double y = (z.y * z.x + z.x * z.y) + c.y;"
Line 52="				//END OF FRACTAL FORMULA"
Line 53="				"
Line 54="				magnitude=(x * x + y * y);"
Line 55="				if(magnitude>bailout_squared) break;"
Line 56="				z.x = x;"
Line 57="				z.y = y;"
Line 58=""
Line 59="				//circles orbit traps"
Line 60="				trapdist=sqrt((z.x-trapy)*(z.x-trapy)+(z.y-trapx)*(z.y-trapx));"
Line 61="            if (trapdist<trapsize) {"
Line 62="					trapped=true;"
Line 63="				}"
Line 64="				if (trapped==true) break;"
Line 65=""
Line 66="			}"
Line 67=""
Line 68="			//trapped?"
Line 69="			if (trapped==true) {"
Line 70="				distpercentage=1-trapdist/trapsize;"
Line 71="				col=vec4(distpercentage,distpercentage,distpercentage,1);"
Line 72="			} else "
Line 73="			if (i==maxiters) {"
Line 74="				col=vec4(0.0,0.0,0.0,1.0);"
Line 75="			} else {"
Line 76="				//CPM smooth colors"
Line 77="				//note that double precision does not support log so it needs to be cast as float"
Line 78="				realiters=float(i+1-((log(log(sqrt(float(magnitude))))/log(2.0))));"
Line 79="				colval=int(mod(realiters,255));"
Line 80="				colval2=int(mod(colval+1,255));"
Line 81="				tweenval=realiters-int(realiters);"
Line 82="				r1=palette[colval].r;"
Line 83="				g1=palette[colval].g;"
Line 84="				b1=palette[colval].b;"
Line 85="				r2=palette[colval2].r;"
Line 86="				g2=palette[colval2].g;"
Line 87="				b2=palette[colval2].b;"
Line 88="				col=vec4(r1+((r2-r1)*tweenval),g1+((g2-g1)*tweenval),b1+((b2-b1)*tweenval),1.0);"
Line 89="			}"
Line 90=""
Line 91="			finalcol+=col;"
Line 92="		}"
Line 93="	}"
Line 94="	gl_FragColor = vec4(finalcol/double(sqrsamplepixels));"
Line 95="}"
Line 96="	"
Line 97="	"
