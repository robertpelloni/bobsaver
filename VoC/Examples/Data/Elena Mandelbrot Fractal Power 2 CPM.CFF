[Settings]
Palette=sinpal14.MAP
Xmin=-4.82354835913835
Xmax=4.4717624241598
Ymin=-2.73518657688345
Ymax=2.65028410818991
Bailout=8
Maxiters=128
[Description]
Total Lines=6
Line 0="Elena Mandelbrot Fractal power 2"
Line 1="CPM coloring"
Line 2="Double precision"
Line 3=""
Line 4="Formula from Elena Novaretti"
